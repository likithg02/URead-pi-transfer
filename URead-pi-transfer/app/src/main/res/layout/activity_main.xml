<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    tools:context=".MainActivity">

    <!-- Scrollable main content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <!-- App Title -->
            <TextView
                android:id="@+id/textView1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="USYNC"
                android:textAlignment="center"
                android:textColor="@color/app_text_primary"
                android:textStyle="bold"
                android:textSize="30sp"
                android:padding="16dp"
                android:elevation="6dp"
                android:background="@color/card_bg"
                android:layout_marginTop="70dp"
                android:layout_marginBottom="10dp"
                android:shadowColor="@color/dark_gray"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3" />

            <!-- Connection indicator -->
            <TextView
                android:id="@+id/connectionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Offline"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:background="@color/honeydew"
                android:padding="8dp"
                android:layout_marginBottom="20dp"
                android:elevation="3dp" />

            <!-- Status bar -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Status: Offline"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="20sp"
                android:background="@color/status_bg"
                android:padding="8dp"
                android:elevation="3dp"
                android:layout_marginBottom="30dp"
                android:layout_marginHorizontal="10dp" />

            <!-- Button Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/button1"
                    style="@style/App.Button.Send"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:text="Send" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/button2"
                    style="@style/App.Button.Receive"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:text="Receive"
                    android:layout_marginStart="15dp" />
            </LinearLayout>

            <!-- Button Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/button3"
                    style="@style/App.Button.Keyboard"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:text="Keyboard" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/button4"
                    style="@style/App.Button.Files"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:text="Files"
                    android:layout_marginStart="15dp" />
            </LinearLayout>

            <!-- Connect Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button6"
                style="@style/App.Button.Primary"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:text="Connect"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center" />

            <!-- Received Files Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button7"
                style="@style/App.Button.ReceivedFiles"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:text="Received Files"
                android:layout_marginBottom="35dp"
                android:layout_gravity="center" />

        </LinearLayout>
    </ScrollView>

    <!-- Floating Settings Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button5"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="@drawable/circle"
        android:foreground="@drawable/ic_settings"
        android:padding="8dp"
        android:contentDescription="Settings" />

</FrameLayout>
