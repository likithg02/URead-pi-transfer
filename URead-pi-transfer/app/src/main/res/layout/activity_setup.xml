<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ivory"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 Raspberry Pi Setup"
            android:textAlignment="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/dark_slate_gray"
            android:background="@color/light_goldenrod_yellow"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="22dp" />

        <!-- STATUS MOVED ABOVE FIELDS -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting..."
            android:textColor="@color/black"
            android:gravity="center"
            android:padding="10dp"
            android:background="@color/pale_turquoise"
            android:layout_marginBottom="16dp" />

        <!-- IP Address -->
        <EditText
            android:id="@+id/ipInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pi IP (auto-filled after WiFi connect)"
            android:textColor="@color/black"
            android:textColorHint="@color/dark_gray"
            android:padding="12dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="12dp" />

        <!-- Username -->
        <EditText
            android:id="@+id/userInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SSH Username"
            android:textColor="@color/black"
            android:textColorHint="@color/dark_gray"
            android:padding="12dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="12dp" />

        <!-- Password + toggle -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/passInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="SSH Password"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:textColorHint="@color/dark_gray"
                android:padding="12dp"
                android:background="@drawable/edittext_bg" />

            <ImageButton
                android:id="@+id/togglePassBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_secure"
                android:contentDescription="Toggle password visibility" />
        </RelativeLayout>

        <!-- Remember Me -->
        <CheckBox
            android:id="@+id/rememberCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remember credentials"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/disconnectBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📘 Known Devices"
            android:textColor="@color/white"
            android:backgroundTint="@color/dark_slate_gray"
            android:textAllCaps="false"
            android:layout_marginBottom="18dp" />

        <!-- Configure WiFi -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/configureBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📶 Configure WiFi (Connect to Pi Hotspot)"
            android:textColor="@color/white"
            android:backgroundTint="@color/light_blue"
            android:textAllCaps="false"
            android:layout_marginBottom="12dp" />
        <!-- Discover Devices -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/discoverBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Discover Devices (Fallback)"
            android:textColor="@color/black"
            android:backgroundTint="@color/light_goldenrod_yellow"
            android:textAllCaps="false"
            android:layout_marginBottom="14dp" />
        <!-- Connect via SSH -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/connectBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔗 Connect to Raspberry Pi (SSH)"
            android:textColor="@color/white"
            android:backgroundTint="@color/sea_green"
            android:textAllCaps="false"
            android:layout_marginBottom="12dp" />

        <!-- KNOWN DEVICES BUTTON (REPLACES DISCONNECT) -->


        <!-- Output logs -->
        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:background="@android:color/white"
            android:padding="10dp"
            android:textColor="@color/black"
            android:text="Output will appear here"
            android:layout_marginBottom="20dp" />

        <!-- Home -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/homeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 Home"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue_A100"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
