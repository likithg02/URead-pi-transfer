<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bluetooth Keyboard"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary"
            android:textAlignment="center"
            android:layout_marginBottom="20dp"
            android:background="@color/card_bg"
            android:padding="14dp"
            android:elevation="5dp" />

        <!-- Connection Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp"
            android:background="@drawable/border_box"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not Connected"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:padding="8dp"
                android:textColor="@color/app_text_primary" />

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnConnect"
                    style="@style/App.Button.Primary"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="40dp"
                    android:text="Connect" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDisconnect"
                    style="@style/App.Button.Primary"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Disconnect"
                    android:backgroundTint="@color/red_400"
                    android:layout_marginStart="20dp" />

            </LinearLayout>
            <!-- NEW SCAN DEVICES BUTTON -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnScan"
                style="@style/App.Button.Primary"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Scan Devices"
                android:backgroundTint="@color/green_400"
                android:layout_gravity="center"
                android:layout_marginTop="15dp" />
        </LinearLayout>

        <!-- Status Bar -->
        <TextView
            android:id="@+id/statusBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idle"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="@color/status_bg"
            android:layout_marginBottom="20dp"
            android:textColor="@color/app_text_primary" />

        <!-- POWER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center"
            android:layout_marginBottom="15dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button1"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:background="@drawable/circle"
                android:backgroundTint="@color/red_400"
                android:text="O"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:elevation="5dp" />
        </LinearLayout>

        <!-- X & Y -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button2"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="60dp"
                android:text="X"
                android:textColor="@color/app_text_primary"
                android:background="@drawable/circle"
                android:backgroundTint="@color/medium_spring_green"
                android:elevation="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="Y"
                android:textColor="@color/app_text_primary"
                android:background="@drawable/circle"
                android:backgroundTint="@color/medium_spring_green"
                android:elevation="4dp" />
        </LinearLayout>

        <!-- UP & + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button4"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="48dp"
                android:text="Up"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:background="@drawable/triangle"
                android:backgroundTint="@color/teal_800"
                android:elevation="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button5"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:background="@drawable/triangle"
                android:backgroundTint="@color/blue_600"
                android:elevation="4dp" />
        </LinearLayout>

        <!-- DOWN & - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button6"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="48dp"
                android:text="Dn"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:background="@drawable/inverted_triangle"
                android:backgroundTint="@color/teal_800"
                android:elevation="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button7"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="-"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:background="@drawable/inverted_triangle"
                android:backgroundTint="@color/blue_600"
                android:elevation="4dp" />
        </LinearLayout>

        <!-- B & C -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button8"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="60dp"
                android:text="B"
                android:textColor="@color/white"
                android:background="@drawable/circle"
                android:backgroundTint="@color/orange_500"
                android:elevation="5dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button9"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="C"
                android:textColor="@color/white"
                android:background="@drawable/circle"
                android:backgroundTint="@color/grey_500"
                android:elevation="5dp" />
        </LinearLayout>

        <!-- A / Play -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center"
            android:layout_marginBottom="30dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button10"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:text="A / Play"
                android:textColor="@color/white"
                android:background="@drawable/circle"
                android:backgroundTint="@color/orange_500"
                android:elevation="5dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
