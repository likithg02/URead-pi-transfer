<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="App.Button.Base" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">18sp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/button_selector</item>
    </style>

    <!-- Individual button styles -->
    <style name="App.Button.Primary" parent="App.Button.Base">
        <item name="android:backgroundTint">@color/btn_primary</item>
    </style>

    <style name="App.Button.Send" parent="App.Button.Base">
        <item name="android:backgroundTint">@color/btn_send</item>
    </style>

    <style name="App.Button.Receive" parent="App.Button.Base">
        <item name="android:backgroundTint">@color/btn_receive</item>
    </style>

    <style name="App.Button.Keyboard" parent="App.Button.Base">
        <item name="android:backgroundTint">@color/btn_keyboard</item>
    </style>

    <style name="App.Button.Files" parent="App.Button.Base">
        <item name="android:backgroundTint">@color/btn_files</item>
    </style>

    <style name="App.Button.ReceivedFiles" parent="App.Button.Base">
        <item name="android:backgroundTint">@color/btn_received_files</item>
    </style>
</resources>
